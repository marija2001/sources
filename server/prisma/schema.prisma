generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String    @unique
  image          String?
  bookmarked     Json[]    // ili lista ID-jeva projekata koje je korisnik sačuvao
  ownedProjects  Project[] @relation("Owner") // povezano sa Project modelom
}
model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // ime projekta ili firme
  description String   // opis firme/projekta
  image       String   // URL slike
  company     String   // ime firme (ako se razlikuje od 'name')
  website     String?  // opcionalno: link ka sajtu
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userEmail   String
  owner       User     @relation("Owner", fields: [userEmail], references: [email])

  @@unique(fields: [name, userEmail]) 
}

/// Prikaz na home-u (HomeServices sekcija). iconKey mapira se na react-icons u klijentu.
model HomeService {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  iconKey   String
  title     String
  blurb     String
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Stranica /team — bio je niz paragrafa (Json niz stringova u bazi).
model TeamMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  role      String
  photo     String
  bio       Json
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}